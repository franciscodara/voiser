<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Usa um capability de assistente para injetar texto cru via URI local. -->
    <capability android:name="actions.intent.CREATE_THING">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="com.codara.finwise.MainActivity">
            <parameter
                android:name="thing.name"
                android:key="query"/>
            <!-- O template URL traduz a fala detectada para um Deep Link de Flutter -->
            <url-template android:value="finwise://voice-entry?query={query}"/>
        </intent>
    </capability>
</shortcuts>
